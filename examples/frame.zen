zenith version=1 {
  project id="proj.frame" name="Frame Example"
  tokens format="zenith-token-v1" {
    token id="color.bg" type="color" value="#f8fafc"
    token id="color.inside" type="color" value="#3b82f6"
    token id="color.overflow" type="color" value="#f97316"
  }
  styles {}
  document id="doc.frame" title="Frame Example" {
    page id="page.frame" w=(px)320 h=(px)200 background=(token)"color.bg" {
      frame id="frame.clip" x=(px)40 y=(px)40 w=(px)120 h=(px)100 {
        rect id="rect.inside" x=(px)50 y=(px)50 w=(px)80 h=(px)60 fill=(token)"color.inside"
        rect id="rect.overflow" x=(px)100 y=(px)30 w=(px)100 h=(px)120 fill=(token)"color.overflow"
      }
    }
  }
}
